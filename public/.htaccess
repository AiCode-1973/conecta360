# =============================================================================
# CONECTA360 — public/.htaccess
# Funciona tanto quando Document Root = project root (via rewrite do .htaccess raiz)
# quanto quando Document Root = public/ (configuração direta no cPanel)
# =============================================================================

Options -Indexes -MultiViews
ServerSignature Off

# ── Bloqueia arquivos sensíveis ───────────────────────────────────────────────
<FilesMatch "\.(env|sql|log|sh|bak|json|lock|md)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# ── Cabeçalhos de segurança ───────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

RewriteEngine On

# ── Força HTTPS (fallback, caso Document Root seja public/) ───────────────────
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# ── Captura subdomínio (para multi-tenant futuro) ─────────────────────────────
RewriteCond %{HTTP_HOST} ^([a-z0-9-]+)\.(.+)$ [NC]
RewriteRule ^ - [E=SUBDOMAIN:%1,E=DOMAIN:%2]

# ── Front Controller ──────────────────────────────────────────────────────────
# Deixa passar arquivos e pastas físicas (assets, uploads)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]

# ── Cabeçalhos de Segurança ───────────────────────────────────────────────────
<IfModule mod_headers.c>
    # Evita clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"

    # Evita MIME sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Proteção básica XSS (legacy, mas ainda útil)
    Header always set X-XSS-Protection "1; mode=block"

    # Referrer Policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Remove header que expõe tecnologia
    Header unset X-Powered-By
    Header always unset X-Powered-By

    # Content-Security-Policy (ajustar conforme CDNs e fontes usadas)
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; frame-ancestors 'none';"

    # HSTS — só ative com HTTPS estável (descomente em produção)
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ── Cache de Assets Estáticos ─────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css             "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType image/png            "access plus 1 year"
    ExpiresByType image/jpeg           "access plus 1 year"
    ExpiresByType image/svg+xml        "access plus 1 year"
    ExpiresByType font/woff2           "access plus 1 year"
</IfModule>

# ── Compressão Gzip ───────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>
